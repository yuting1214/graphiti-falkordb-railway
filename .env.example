# ── Required ────────────────────────────────────────────────────────────────
# LLM key used by Graphiti for entity extraction + embeddings.
OPENAI_API_KEY=sk-...

# ── Database auth (auto-generated on Railway) ─────────────────────────────────
# Locally, pick anything; on Railway this is a ${{ secret(16) }} shared to both
# services. Must match between the falkordb and graphiti services.
FALKORDB_PASSWORD=changeme

# ── Optional knobs (sensible defaults shown) ──────────────────────────────────
# MODEL_NAME=gpt-4o-mini                # LLM used for extraction
# EMBEDDER_MODEL=text-embedding-3-small # embedding model
# FALKORDB_DATABASE=default_db          # graph/database name
# GRAPHITI_GROUP_ID=main                # namespace for episodes/graph partition
# SEMAPHORE_LIMIT=10                    # LLM concurrency; lower to 1-5 on free tiers
# BROWSER=1                             # 0 disables the FalkorDB :3000 web UI
# FALKORDB_URI=redis://falkordb:6379    # set by the template on Railway

# Connecting to a non-OpenAI provider (Anthropic/Gemini/Azure/Groq)? See docs/USAGE.md.
